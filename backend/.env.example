# Database
DATABASE_URL=postgresql://xeed:xeedpassword@localhost:5432/xeedcrm

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Google Gemini API (free — get key at aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# Google OAuth (for Gmail)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3001/api/gmail/callback as an Authorized redirect URI
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gmail/callback
